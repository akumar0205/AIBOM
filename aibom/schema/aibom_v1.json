{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/aibom_v1.json",
  "title": "AIBOM v1",
  "type": "object",
  "required": [
    "coverage_summary",
    "datasets",
    "frameworks",
    "metadata",
    "models",
    "risk_findings",
    "schema_version",
    "tools",
    "unsupported_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "generated_at",
        "git_sha",
        "artifact_sha256"
      ],
      "properties": {
        "generated_at": {
          "type": "string"
        },
        "git_sha": {
          "type": "string"
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "model",
          "source_file"
        ],
        "properties": {
          "provenance": {
            "$ref": "#/$defs/provenance"
          }
        },
        "additionalProperties": true
      }
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "source_file"
        ]
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source_file"
        ]
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ]
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source_file"
        ]
      }
    },
    "risk_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "owasp_llm",
          "heuristic"
        ]
      }
    },
    "scan_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "source_type",
          "source_file",
          "severity",
          "confidence"
        ]
      }
    },
    "source_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "default_severity",
          "default_confidence"
        ]
      }
    },
    "coverage_summary": {
      "type": "object",
      "required": [
        "detectors",
        "unsupported_total"
      ],
      "properties": {
        "detectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "source_type",
              "artifacts_seen",
              "artifacts_scanned",
              "default_confidence"
            ]
          }
        },
        "unsupported_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "unsupported_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "artifact_type",
          "reason"
        ]
      }
    },
    "risk_policy": {
      "type": "object",
      "required": [
        "policy",
        "applied_rules",
        "suppressed"
      ],
      "properties": {
        "policy": {
          "type": "object",
          "required": [
            "policy_id",
            "version",
            "source",
            "sha256"
          ]
        },
        "applied_rules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "suppressed": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "runtime_context": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": [
        "provider_endpoint",
        "registry_uri",
        "immutable_version",
        "environment",
        "region"
      ],
      "properties": {
        "provider_endpoint": {
          "type": "string"
        },
        "registry_uri": {
          "type": "string"
        },
        "immutable_version": {
          "type": "string"
        },
        "environment": {
          "type": "string"
        },
        "region": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
